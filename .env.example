# ============================================
# Token Launch Forensics Bot - Configuration
# ============================================
# Copy to config/.env and fill in your values
# On Railway: set these as Environment Variables in the dashboard

# --- REQUIRED ---

# Solana RPC (get key at https://helius.dev)
HELIUS_API_KEY=your_helius_key_here

# Telegram Bot (create via @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# --- SECURITY ---

# Strong random API key for the dashboard (all /api/* and /ws endpoints).
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Required in production — leave empty only for local development.
ADMIN_API_KEY=

# Comma-separated Telegram user IDs allowed to run privileged commands
# (/export, /train, /backtest, /lookup).  Find your ID via @userinfobot.
# Leave empty to disable the restriction (not recommended in production).
TELEGRAM_OWNER_IDS=

# --- DATABASE ---
# Local dev: SQLite (default, no config needed)
# Railway: automatically set by PostgreSQL addon → railway add postgresql
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# --- OPTIONAL: Sniper Bridge ---
# HTTP webhook URL for buy signals (your sniper bot endpoint)
SNIPER_WEBHOOK_URL=
# Telegram chat for sniper-specific alerts (can be same as TELEGRAM_CHAT_ID)
SNIPER_SIGNAL_CHAT_ID=
# Max risk score to trigger a buy signal (0-100)
SNIPER_MAX_RISK_SCORE=30

# --- OPTIONAL: Public Channel ---
# Telegram channel ID for public alpha alerts (e.g. @YourChannel or -100xxxx)
CHANNEL_CHAT_ID=
# Min score to post warning (default 70)
CHANNEL_MIN_WARNING_SCORE=70
# Max score to post gem alert (default 25)
CHANNEL_MAX_GEM_SCORE=25

# --- OPTIONAL: Redis ---
# Railway: automatically set by Redis addon → railway add redis
# REDIS_URL=redis://localhost:6379
# Enable Redis-backed job queue (default: false, uses asyncio queue)
USE_REDIS_QUEUE=false
QUEUE_WORKERS=3

# --- OPTIONAL: Social ---
# Twitter/X API bearer token for social sentiment scanning
TWITTER_BEARER_TOKEN=

# --- TUNING ---
# Min risk score to send Telegram alerts (default 50)
MIN_RISK_SCORE_ALERT=50
ALERT_COOLDOWN_SECONDS=30
SCAN_CONCURRENCY=5
HOLDER_CHECK_TOP_N=10
MAX_DEPLOYER_HISTORY_LOOKBACK=50

# Post-rug fund tracker (traces where SOL goes after rugs)
POST_RUG_TRACKER_ENABLED=true
POST_RUG_CHECK_INTERVAL=300

# --- DASHBOARD ---
# Railway sets PORT automatically, no need to configure
# DASHBOARD_PORT=8080
# DASHBOARD_HOST=0.0.0.0

